Algoritmo EvaluacionNotas
	Definir nota Como Caracter
	Escribir Sin Saltar "DIME TU NOTA EN LETRAS"
	Leer nota
	
	Segun nota Hacer
		"A":
			Escribir "EXCELENTE"
		"B":
			Escribir "BUENO"
		"C":
			Escribir "REGULAR"
		"D":
			Escribir "DEFICIENTE"
		"F":
			Escribir "REPROBADO"
		De Otro Modo:
			Escribir "LETRA INVALIDA!!!"
	Fin Segun
FinAlgoritmo
